{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,

    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "lib": ["ESNext", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@noted/types": ["libs/shared/types/src/index.ts"],
      "@noted/types/*": ["libs/shared/types/src/lib/*"],
      "@noted/common": ["libs/shared/common/src/index.ts"],
      "@noted/common/*": ["libs/shared/common/src/lib/*"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
